{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "counselor", "admin"] },
        "interests": { "type": "array", "items": { "type": "string" } },
        "skills": { "type": "array", "items": { "type": "string" } },
        "bio": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "CareerPath": {
      "title": "CareerPath",
      "description": "Information about a specific career path",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "skillsRequired": { "type": "array", "items": { "type": "string" } },
        "resources": { "type": "array", "items": { "$ref": "Resource" } },
        "salaryRange": { "type": "string" },
        "demand": { "type": "string" }
      },
      "required": ["title", "description"]
    },
    "Resource": {
      "title": "Resource",
      "description": "Career resource or article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["article", "video", "link"] },
        "url": { "type": "string" },
        "category": { "type": "string" },
        "authorId": { "type": "string" }
      },
      "required": ["title", "type"]
    },
    "CounselingSession": {
      "title": "CounselingSession",
      "description": "A scheduled counseling session",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "counselorId": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "notes": { "type": "string" },
        "meetingLink": { "type": "string" }
      },
      "required": ["studentId", "counselorId", "scheduledAt", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/careerPaths/{pathId}": {
      "schema": "CareerPath",
      "description": "Career path information"
    },
    "/resources/{resourceId}": {
      "schema": "Resource",
      "description": "Career resources"
    },
    "/sessions/{sessionId}": {
      "schema": "CounselingSession",
      "description": "Counseling sessions"
    }
  }
}
